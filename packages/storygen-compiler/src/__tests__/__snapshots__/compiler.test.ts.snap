exports[`compileInk > produces deterministic Ink source 1`] = `
"// Ink export — generated by @ch5me/storygen-compiler
// Project: proj_rooftop — Story: story_main (One Good Rooftop)

VAR met_devin = false
VAR affection = 0

-> scene_arrival

=== scene_arrival ===
The rooftop bar glows against a bruise-blue sky.
Mara: Quite a view.
* [Walk over]
    ~ met_devin = true
    -> scene_meet
* [Stay and watch the skyline]
    -> scene_linger

=== scene_meet ===
Devin: You have good taste in rooftops.
~ affection = 1
Mara: And you have good taste in opening lines.
-> scene_close

=== scene_linger ===
You let the moment pass, content with the quiet.
-> scene_close

=== scene_close ===
The night folds on, full of roads not yet taken.
-> END
"
`;

exports[`compileRenpy > produces a deterministic .rpy script 1`] = `
"# Ren'Py export — generated by @ch5me/storygen-compiler
# Project: proj_rooftop — Story: story_main (One Good Rooftop)
# Do not edit by hand; regenerate from the canonical story DB.

define char_mara = Character("Mara")
define char_devin = Character("Devin")

label start:
    jump scene_arrival

label scene_arrival:
    "The rooftop bar glows against a bruise-blue sky."
    char_mara "Quite a view."
    menu:
        "Approach the stranger by the bar?"
        "Walk over":
            $ met_devin = True
            jump scene_meet
        "Stay and watch the skyline":
            jump scene_linger
    return

label scene_meet:
    char_devin "You have good taste in rooftops."
    $ affection = 1
    char_mara "And you have good taste in opening lines."
    jump scene_close
    return

label scene_linger:
    "You let the moment pass, content with the quiet."
    jump scene_close
    return

label scene_close:
    "The night folds on, full of roads not yet taken."
    return
"
`;

