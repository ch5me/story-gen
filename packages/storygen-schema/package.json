{
  "name": "@ch5me/storygen-schema",
  "version": "0.1.0",
  "private": true,
  "description": "Canonical Zod + Drizzle domain schema and shared types for StoryGen.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "drizzle-orm": "^0.39.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250507.0",
    "drizzle-kit": "^0.30.5",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
