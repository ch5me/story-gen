{
  "name": "@ch5me/storygen-reader",
  "version": "0.1.0",
  "private": true,
  "description": "StoryGen runtime: plays a compiled story manifest (advance dialogue, choose route).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ch5me/storygen-compiler": "workspace:*",
    "@ch5me/storygen-player": "workspace:*",
    "@ch5me/storygen-schema": "workspace:*",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^25.0.0",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}
